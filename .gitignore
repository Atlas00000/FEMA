# --- Fat telemetry / datasets (AI) ---
# Keep schemas & live/artifacts README + .gitkeep only
AI/data/**
!AI/data/live/
AI/data/live/**
!AI/data/live/README.md
!AI/data/live/.gitkeep
!AI/data/artifacts/
AI/data/artifacts/**
!AI/data/artifacts/README.md
!AI/data/artifacts/.gitkeep

# --- Ops drop zone (sync CSVs) ---
# Keep directory markers; ignore synced baskets/events/meta
ops/incoming/**
!ops/incoming/demo/
!ops/incoming/tester/
!ops/incoming/demo/.gitkeep
!ops/incoming/tester/.gitkeep

# --- AER Tester artifacts ---
# Large MT5 HTML reports (copied by launch.ps1)
ops/tester_queue/reports/**
!ops/tester_queue/reports/.gitkeep

# Optional local scratch under queue (do not commit dumps)
ops/tester_queue/*.tmp
ops/tester_queue/*.bak

# --- Docker local overrides ---
docker-compose.override.yml
ops/docker-compose.override.yml
